# =============================================================================
# Atlas Health Sentinel — environment configuration
# Copy this file to .env and fill in real values. Do NOT commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Atlas — data plane
# -----------------------------------------------------------------------------
# Two connection strings: agent uses read-only, app uses read/write.
# Get these from: Atlas UI → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://sentinel_agent:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_APP_URI=mongodb+srv://sentinel_app:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name (collections live here: orders, analytics, past_incidents)
MONGODB_DB=sentinel_db

# Cluster display name (shown in UI header)
MONGODB_CLUSTER_NAME=sentinel-cluster

# -----------------------------------------------------------------------------
# Atlas Admin API — for metrics, alerts, slow queries, suggested indexes
# -----------------------------------------------------------------------------
# Generate from: Atlas UI → Organization Settings → Access Manager → API Keys
# Required permissions: Project Read Only + Project Data Access Read Only
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=

# Project (Group) ID — get from: Project Settings → Project ID (24-char hex)
ATLAS_GROUP_ID=

# -----------------------------------------------------------------------------
# Voyage AI — embeddings for institutional memory
# -----------------------------------------------------------------------------
# Sign up at https://dashboard.voyageai.com/
# IMPORTANT: Add a payment method to unlock standard rate limits.
# 200M tokens/month free for voyage-3 series (we use ~5K tokens total).
VOYAGE_API_KEY=

# -----------------------------------------------------------------------------
# Grove — MongoDB's internal GenAI gateway (Azure-backed Anthropic models)
# -----------------------------------------------------------------------------
# Request L1 access at https://grove.aix.prod.corp.mongodb.com/
# After approval, the Usage tab shows the exact base URL + API key + model names.
GROVE_BASE_URL=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/anthropic/v1
GROVE_API_KEY=

# Model names — exact deployment names from your Grove request
# Fast model: tool-use loop (8-12 calls per diagnostic)
GROVE_MODEL_FAST=claude-haiku-4-5
# Smart model: final report synthesis (1 call per diagnostic)
GROVE_MODEL_SMART=claude-sonnet-4-5

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000